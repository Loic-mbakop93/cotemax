# ── CoteMax – Variables d'environnement ──
# Copier ce fichier en .env.local et remplir les valeurs
# Sur Cloudflare Pages: ajouter sous Settings > Environment Variables

# Supabase (frontend)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Edge Function secrets (à configurer dans Supabase Dashboard > Edge Functions > Secrets)
# ODDS_API_KEY=1147caef60217f0072de7f20750ad60c
